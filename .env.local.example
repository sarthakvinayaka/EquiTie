# OpenAI API key — get one at https://platform.openai.com/api-keys
# Without this key the app runs in template mode: answers are deterministic
# structured templates, not LLM-phrased. All financial numbers remain correct.
OPENAI_API_KEY=sk-...

# Your deployed URL — used to build absolute OG image URLs.
# Set this in Vercel environment variables to your actual domain.
# Defaults to https://equitie.vercel.app if not set.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
